{
  "name": "politistream",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'npm run dev:backend & backend=$!; npm run dev:frontend; kill $backend 2>/dev/null'",
    "start:all": "node scripts/start-all.mjs",
    "dev:backend": "tsx server.ts",
    "dev:frontend": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "npm run test:runtime && npm run test:research && npm run test:research-platform && npm run test:analytics && npm run test:analytics-import && npm run test:analytics-worker && npm run test:agent && npm run test:i18n && npm run test:ui",
    "test:full": "npm run test && npm run test:research-e2e && npm run benchmark:research && npm run lint && npm run build",
    "test:runtime": "tsx src/server/runtime.test.ts",
    "test:research": "tsx src/server/research/research.test.ts",
    "test:research-platform": "tsx src/server/research/platform.test.ts",
    "test:research-e2e": "node scripts/research-e2e-smoke.mjs",
    "test:analytics": "tsx src/server/analytics/analytics.test.ts",
    "test:analytics-import": "tsx src/server/analytics/import.integration.test.ts",
    "test:analytics-worker": "node scripts/analytics-worker-smoke.mjs",
    "test:agent": "tsx src/server/agent/agent.test.ts",
    "test:i18n": "tsx src/i18n.test.ts",
    "test:ui": "node scripts/ui-smoke.mjs",
    "check:postgres": "tsx scripts/check-postgres.ts",
    "benchmark:research": "tsx src/server/research/evaluation/benchmarkRunner.ts",
    "smoke:research-capabilities": "node --import tsx scripts/research-capability-smoke.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.4.1",
    "bullmq": "^5.77.6",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ioredis": "^5.11.0",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "puppeteer": "^24.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rss-parser": "^3.13.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "playwright-core": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
