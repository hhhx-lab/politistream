# PolitiStream 环境变量模板

# GEMINI_API_KEY: 访问 Gemini AI API 所需的密钥。
# 可以在 https://aistudio.google.com/app/apikey 获取。
GEMINI_API_KEY="您的_GEMINI_API_KEY"

# APP_URL: 应用程序托管的 URL（可选）。
APP_URL="http://localhost:3000"

# 端口号
PORT=3000

# Research crawler storage and queue.
# When these are missing, research APIs should report a clear configuration error
# while legacy RSS/news APIs continue to work.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/politistream"
REDIS_URL="redis://localhost:6379"

# Search discovery providers.
BRAVE_API_KEY=""
SERPAPI_API_KEY=""
TAVILY_API_KEY=""
