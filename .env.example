# PolitiStream 环境变量示例
#
# 使用方式：
# 1. 将本文件复制为 `.env`。
# 2. 只填写你实际需要启用的 key。
# 3. `.env` 只放在本机，不能提交真实 API key、本地数据库密码或代理配置。

# -----------------------------------------------------------------------------
# 应用地址与本地开发端口
# -----------------------------------------------------------------------------

# APP_URL
# 是什么：
# - 前端应用的访问地址。
# - 后端会用它做 CORS 校验，只允许这个来源的浏览器请求访问 API。
# 怎么获得/怎么填：
# - 本地开发保持 `http://localhost:3000`。
# - 如果部署到线上，改成你的前端域名，例如 `https://your-app.example.com`。
# 是否必填：
# - 建议填写。代码缺省值是 `http://localhost:3000`。
APP_URL="http://localhost:3000"

# FRONTEND_PORT
# 是什么：
# - Vite + React 前端开发服务使用的端口。
# 怎么获得/怎么填：
# - 本地默认 `3000`。
# - 只有当 3000 被占用时才需要改。
# 是否必填：
# - 可选。Vite 配置里的缺省值是 `3000`。
FRONTEND_PORT=3000

# BACKEND_PORT
# 是什么：
# - Express 后端 API 服务使用的端口。
# 怎么获得/怎么填：
# - 本地默认 `3001`。
# - 只有当 3001 被占用时才需要改。
# 是否必填：
# - 可选。`src/server/runtime.ts` 里的缺省值是 `3001`。
BACKEND_PORT=3001

# VITE_API_PROXY_TARGET
# 是什么：
# - Vite 开发服务器把前端 `/api/*` 请求代理到哪个后端地址。
# - 前端代码请求 `/api/...`，Vite 会转发到这里。
# 怎么获得/怎么填：
# - 本地开发保持 `http://localhost:3001`。
# - 如果后端跑在别的端口或机器上，改成那个后端地址。
# 是否必填：
# - 本地开发建议填写。
VITE_API_PROXY_TARGET="http://localhost:3001"

# API_URL
# 是什么：
# - `vite.config.ts` 里的旧版兼容代理目标。
# - 如果 `VITE_API_PROXY_TARGET` 缺失，才会读取这个变量。
# 怎么获得/怎么填：
# - 通常留空，优先使用 `VITE_API_PROXY_TARGET`。
# 是否必填：
# - 可选。
API_URL=""

# DISABLE_HMR
# 是什么：
# - 是否禁用 Vite 热更新。设置为 `true` 时禁用。
# 怎么获得/怎么填：
# - 本地开发保持 `false`。
# - 只有当热更新和网络/代理冲突时才设为 `true`。
# 是否必填：
# - 可选。
DISABLE_HMR=false

# RSS_REFRESH_ON_STARTUP
# 是什么：
# - 后端启动时是否立刻刷新所有启用的 RSS 源。
# 怎么获得/怎么填：
# - 本地开发建议保持 `false`，启动更快。
# - 如果希望后端一启动就抓取 RSS，设置为 `true`。
# 是否必填：
# - 可选。缺省为 `false`。
RSS_REFRESH_ON_STARTUP=false

# -----------------------------------------------------------------------------
# AI 分析
# -----------------------------------------------------------------------------

# GEMINI_API_KEY
# 是什么：
# - Google Gemini API key，用于：
#   - 新闻摘要、情感分值、实体提取。
#   - Research 文档相关性判断和证据抽取。
# 怎么获得：
# - 打开 Google AI Studio：https://aistudio.google.com/app/apikey
# - 创建或选择一个 API key。
# - 把 key 粘贴到这里。
# 是否必填：
# - 只看 RSS/新闻列表时不必填。
# - 要生成真实 AI 摘要、AI 证据抽取时必须填写。
# 本地降级：
# - 留空时 AI 会禁用，页面和 API 仍可运行，但摘要/证据分析会降级。
GEMINI_API_KEY=""

# -----------------------------------------------------------------------------
# Research 爬虫存储与队列
# -----------------------------------------------------------------------------

# DATABASE_URL
# 是什么：
# - Postgres 连接字符串。
# - 用来保存深度研究任务、候选 URL、抓取文档、证据和报告。
# 怎么获得：
# - 本地 Postgres：
#   1. 创建名为 `politistream` 的数据库。
#   2. 把你的本地用户名、密码、端口填进连接串。
# - Docker 示例：
#   `docker run --name politistream-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=politistream -p 5432:5432 -d postgres:16`
# 是否必填：
# - 只看 RSS/新闻时不必填。
# - 创建和运行 Research 任务时必须填写。
DATABASE_URL="postgres://postgres:postgres@localhost:5432/politistream"

# REDIS_URL
# 是什么：
# - Redis 连接字符串。
# - 队列化 Research 爬虫 worker 会基于 Redis/BullMQ 管理 run 入队、后台执行和重试。
# 怎么获得：
# - Docker 示例：
#   `docker run --name politistream-redis -p 6379:6379 -d redis:7`
# - 或者填你已有的 Redis 地址。
# 是否必填：
# - 只看 RSS/新闻时不必填。
# - 创建和运行 Research run 时必须填写；缺失时 Research API 会返回队列配置错误，但 RSS 新闻不受影响。
REDIS_URL="redis://localhost:6379"

# RESEARCH_WORKER_CONCURRENCY
# 是什么：
# - Research worker 同时处理多少个 run。
# - 每个 run 内部还会按 frontier 优先级逐步抓取 URL。
# 怎么获得/怎么填：
# - 本地开发建议 `1` 或 `2`。
# - 机器和搜索/抓取 API 限额更高时可以逐步增大。
# 是否必填：
# - 可选。缺省为 `2`。
RESEARCH_WORKER_CONCURRENCY=2

# -----------------------------------------------------------------------------
# 搜索发现服务
# -----------------------------------------------------------------------------

# BRAVE_API_KEY
# 是什么：
# - Brave Search API key。
# - 用作深度研究的网页搜索 discovery provider。
# 怎么获得：
# - 打开 https://api.search.brave.com/
# - 创建 API subscription/key。
# - 把 key 粘贴到这里。
# 是否必填：
# - 如果使用 SerpApi 或 Tavily，可以不填。
# - 要做真实网页搜索，至少需要填写一个搜索 provider key。
BRAVE_API_KEY=""

# SERPAPI_API_KEY
# 是什么：
# - SerpApi API key。
# - 通过 SerpApi 获取 Google 风格搜索结果。
# 怎么获得：
# - 打开 https://serpapi.com/
# - 注册后进入 dashboard，复制 private API key。
# 是否必填：
# - 如果使用 Brave 或 Tavily，可以不填。
# - 要做真实网页搜索，至少需要填写一个搜索 provider key。
SERPAPI_API_KEY=""

# TAVILY_API_KEY
# 是什么：
# - Tavily Search API key。
# - 用作偏研究场景的搜索 provider。
# 怎么获得：
# - 打开 https://tavily.com/
# - 注册后进入 dashboard/API keys 页面，复制 API key。
# 是否必填：
# - 如果使用 Brave 或 SerpApi，可以不填。
# - 要做真实网页搜索，至少需要填写一个搜索 provider key。
TAVILY_API_KEY=""

# GITHUB_TOKEN
# 是什么：
# - GitHub Personal Access Token。
# - GitHub discovery/extractor 可无 token 运行，但 GitHub API 未认证请求限额很低。
# - 填写后可提高 repo 搜索、README、stars、license、release 等元数据抓取稳定性。
# 怎么获得：
# - 打开 https://github.com/settings/tokens
# - 创建 fine-grained token 或 classic token。
# - 公开仓库调研通常不需要额外权限，保持只读即可。
# 是否必填：
# - 可选。需要大量调研 GitHub 项目时建议填写。
GITHUB_TOKEN=""

# -----------------------------------------------------------------------------
# Research 抓取策略
# -----------------------------------------------------------------------------

# RESEARCH_FETCH_MAX_ATTEMPTS
# 是什么：
# - 单个 URL 抓取失败后的最大尝试次数。
# - 对 429、5xx、超时等临时错误会重试；404 这类确定失败不会无意义重试。
# 怎么获得/怎么填：
# - 本地开发建议 `3`。
# - 如果搜索 provider 或目标站点经常限流，可以降低并发而不是盲目增大这个值。
# 是否必填：
# - 可选。缺省为 `3`。
RESEARCH_FETCH_MAX_ATTEMPTS=3

# RESEARCH_DOMAIN_MIN_DELAY_MS
# 是什么：
# - 同一个域名两次抓取之间的最小间隔，单位毫秒。
# - 用来做礼貌抓取，降低被目标站点限流或封禁的概率。
# 怎么获得/怎么填：
# - 本地开发建议 `1500`。
# - 更深度抓取时建议保持或增大，不建议设置为 0。
# 是否必填：
# - 可选。缺省为 `1500`。
RESEARCH_DOMAIN_MIN_DELAY_MS=1500

# RESEARCH_RESPECT_ROBOTS_TXT
# 是什么：
# - 是否读取并尊重目标站点的 robots.txt。
# 怎么获得/怎么填：
# - 生产与真实调研建议保持 `true`。
# - 只有本地 mock/test 场景才考虑设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_RESPECT_ROBOTS_TXT=true

# RESEARCH_BROWSER_FETCH_ENABLED
# 是什么：
# - 是否允许对动态网页启用 Puppeteer 浏览器抓取 fallback。
# - 当静态 HTML 抓不到正文、或 URL 明显是 SPA 时会用到。
# 怎么获得/怎么填：
# - 本地机器安装依赖后可保持 `true`。
# - 如果机器资源紧张、CI 不希望启动浏览器，可设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_BROWSER_FETCH_ENABLED=true

# RESEARCH_BROWSER_MAX_PAGES
# 是什么：
# - Puppeteer 同时打开的最大页面数。
# 怎么获得/怎么填：
# - 本地开发建议 `2`。
# - 机器性能更强时可逐步增大，但要配合域名限速和总 URL 预算。
# 是否必填：
# - 可选。缺省为 `2`。
RESEARCH_BROWSER_MAX_PAGES=2

# RESEARCH_FETCH_TIMEOUT_MS
# 是什么：
# - 单次 HTTP 或浏览器抓取的超时时间，单位毫秒。
# 怎么获得/怎么填：
# - 本地开发建议 `15000`。
# - 网络较慢或 PDF 较多时可增大到 `30000`。
# 是否必填：
# - 可选。缺省为 `15000`。
RESEARCH_FETCH_TIMEOUT_MS=15000

# RESEARCH_MAX_CONTENT_BYTES
# 是什么：
# - 单个响应允许读取的最大字节数。
# - 防止超大 HTML/PDF 把内存或数据库拖垮。
# 怎么获得/怎么填：
# - 默认 `5242880`，约 5MB。
# - 如需抓较大 PDF，可适当增大。
# 是否必填：
# - 可选。缺省为 5MB。
RESEARCH_MAX_CONTENT_BYTES=5242880

# -----------------------------------------------------------------------------
# Research 原始内容资产
# -----------------------------------------------------------------------------

# RESEARCH_ASSET_DIR
# 是什么：
# - Research 原始 HTML、PDF、抽取文本的本地保存目录。
# - Postgres 保存 metadata 和索引，原始大文件保存在这个目录，避免数据库无限膨胀。
# 怎么获得/怎么填：
# - 本地开发建议保持 `.data/research-assets`。
# - 线上可换成挂载磁盘目录；后续也可以替换为对象存储。
# 是否必填：
# - 可选。缺省为 `.data/research-assets`。
RESEARCH_ASSET_DIR=".data/research-assets"

# RESEARCH_STORE_RAW_HTML
# 是什么：
# - 是否保存抓取到的原始 HTML/XML/text 响应。
# 怎么获得/怎么填：
# - 调试抓取质量和复查来源时建议 `true`。
# - 存储空间紧张时可设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_STORE_RAW_HTML=true

# RESEARCH_STORE_RAW_PDF
# 是什么：
# - 是否保存抓取到的原始 PDF 文件。
# 怎么获得/怎么填：
# - 需要复核 PDF 原文时建议 `true`。
# - 如果只保留抽取文本，可设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_STORE_RAW_PDF=true

# RESEARCH_STORE_RAW_TEXT
# 是什么：
# - 是否把抽取后的正文文本另存为 `.txt` 资产。
# 怎么获得/怎么填：
# - 建议保持 `true`，便于后续离线检索、调试和报告复核。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_STORE_RAW_TEXT=true

# -----------------------------------------------------------------------------
# Research 记忆复用
# -----------------------------------------------------------------------------

# RESEARCH_MEMORY_ENABLED
# 是什么：
# - 是否允许后续 Research run 复用历史已抓取文档和来源记忆。
# 怎么获得/怎么填：
# - 本地和生产建议保持 `true`，可以减少重复抓取并加快同主题调研。
# - 如果需要强制每次重新抓取，设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_MEMORY_ENABLED=true

# RESEARCH_MEMORY_MAX_AGE_HOURS
# 是什么：
# - 历史文档可被复用的最大年龄，单位小时。
# 怎么获得/怎么填：
# - 新闻溯源建议较短，例如 `24`。
# - 工具/技术文档调研可设为 `72` 或更高。
# 是否必填：
# - 可选。缺省为 `24`。
RESEARCH_MEMORY_MAX_AGE_HOURS=24
