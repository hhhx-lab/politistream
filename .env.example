# PolitiStream 环境变量示例
#
# 使用方式：
# 1. 将本文件复制为 `.env`。
# 2. 只填写你实际需要启用的 key。
# 3. `.env` 只放在本机，不能提交真实 API key、本地数据库密码或代理配置。

# -----------------------------------------------------------------------------
# 应用地址与本地开发端口
# -----------------------------------------------------------------------------

# APP_URL
# 是什么：
# - 前端应用的访问地址。
# - 后端会用它做 CORS 校验，只允许这个来源的浏览器请求访问 API。
# 怎么获得/怎么填：
# - 本地开发保持 `http://localhost:3000`。
# - 如果部署到线上，改成你的前端域名，例如 `https://your-app.example.com`。
# 是否必填：
# - 建议填写。代码缺省值是 `http://localhost:3000`。
APP_URL="http://localhost:3000"

# FRONTEND_PORT
# 是什么：
# - Vite + React 前端开发服务使用的端口。
# 怎么获得/怎么填：
# - 本地默认 `3000`。
# - 只有当 3000 被占用时才需要改。
# 是否必填：
# - 可选。Vite 配置里的缺省值是 `3000`。
FRONTEND_PORT=3000

# BACKEND_PORT
# 是什么：
# - Express 后端 API 服务使用的端口。
# 怎么获得/怎么填：
# - 本地默认 `3001`。
# - 只有当 3001 被占用时才需要改。
# 是否必填：
# - 可选。`src/server/runtime.ts` 里的缺省值是 `3001`。
BACKEND_PORT=3001

# VITE_API_PROXY_TARGET
# 是什么：
# - Vite 开发服务器把前端 `/api/*` 请求代理到哪个后端地址。
# - 前端代码请求 `/api/...`，Vite 会转发到这里。
# 怎么获得/怎么填：
# - 本地开发保持 `http://localhost:3001`。
# - 如果后端跑在别的端口或机器上，改成那个后端地址。
# 是否必填：
# - 本地开发建议填写。
VITE_API_PROXY_TARGET="http://localhost:3001"

# API_URL
# 是什么：
# - `vite.config.ts` 里的旧版兼容代理目标。
# - 如果 `VITE_API_PROXY_TARGET` 缺失，才会读取这个变量。
# 怎么获得/怎么填：
# - 通常留空，优先使用 `VITE_API_PROXY_TARGET`。
# 是否必填：
# - 可选。
API_URL=""

# DISABLE_HMR
# 是什么：
# - 是否禁用 Vite 热更新。设置为 `true` 时禁用。
# 怎么获得/怎么填：
# - 本地开发保持 `false`。
# - 只有当热更新和网络/代理冲突时才设为 `true`。
# 是否必填：
# - 可选。
DISABLE_HMR=false

# RSS_REFRESH_ON_STARTUP
# 是什么：
# - 后端启动时是否立刻刷新所有启用的 RSS 源。
# 怎么获得/怎么填：
# - 本地开发建议保持 `false`，启动更快。
# - 如果希望后端一启动就抓取 RSS，设置为 `true`。
# 是否必填：
# - 可选。缺省为 `false`。
RSS_REFRESH_ON_STARTUP=false

# -----------------------------------------------------------------------------
# AI 分析
# -----------------------------------------------------------------------------

# GEMINI_API_KEY
# 是什么：
# - Google Gemini API key，用于：
#   - 新闻摘要、情感分值、实体提取。
#   - Research 文档相关性判断和证据抽取。
# 怎么获得：
# - 打开 Google AI Studio：https://aistudio.google.com/app/apikey
# - 创建或选择一个 API key。
# - 把 key 粘贴到这里。
# 是否必填：
# - 只看 RSS/新闻列表时不必填。
# - 要生成真实 AI 摘要、AI 证据抽取时必须填写。
# 本地降级：
# - 留空时 AI 会禁用，页面和 API 仍可运行，但摘要/证据分析会降级。
GEMINI_API_KEY=""

# AI_PROVIDER
# 是什么：
# - 平台级 AI provider 选择。
# - 当前新增的 Agent 调度和 Research/Analytics 规划默认按 OpenAI 兼容模型配置。
# 怎么获得/怎么填：
# - 使用 OpenAI 时填 `openai`。
# - 如果后续接入 Gemini、Claude 或本地模型，可在代码适配后改成对应 provider。
# 是否必填：
# - 可选。缺省为 `openai`。
AI_PROVIDER="openai"

# OPENAI_API_KEY
# 是什么：
# - OpenAI API key，用于后续 Agent 调度、深度研究规划、证据分析、统计解释和报告生成。
# 怎么获得：
# - 打开 https://platform.openai.com/api-keys
# - 创建 API key 后填入。
# 是否必填：
# - 只使用 RSS/手动页面时不必填。
# - 需要真实 OpenAI 模型推理时必填。
OPENAI_API_KEY=""

# AI_MODEL
# 是什么：
# - 平台默认模型名。所有 Research/Agent/Analytics 需要大模型的地方都应从这里读取。
# 怎么获得/怎么填：
# - 按你的 OpenAI 账号可用模型填写。
# - 用户当前希望默认使用 `gpt-5.4`。
# 是否必填：
# - 可选。代码缺省为 `gpt-5.4`。
AI_MODEL="gpt-5.4"

# OPENAI_MODEL
# 是什么：
# - 旧变量/兼容变量。若 `AI_MODEL` 缺失，代码会读取它。
# 怎么获得/怎么填：
# - 通常留空，优先使用 `AI_MODEL`。
# 是否必填：
# - 可选。
OPENAI_MODEL=""

# -----------------------------------------------------------------------------
# Research 爬虫存储与队列
# -----------------------------------------------------------------------------

# DATABASE_URL
# 是什么：
# - Postgres 连接字符串。
# - 用来保存深度研究任务、候选 URL、抓取文档、证据和报告。
# 怎么获得：
# - 推荐使用本项目自带 Docker Compose，避免占用或误连其它项目的 5432：
#   `docker compose up -d postgres`
# - Compose 会创建：
#   用户：`politistream`
#   密码：`politistream`
#   数据库：`politistream`
#   本机端口：`15432`
# - 如果你使用自己的 Postgres，请把用户名、密码、主机、端口、数据库名替换成真实值。
# 是否必填：
# - 只看 RSS/新闻时不必填。
# - 创建和运行 Research 任务时必须填写。
DATABASE_URL="postgres://politistream:politistream@localhost:15432/politistream"

# REDIS_URL
# 是什么：
# - Redis 连接字符串。
# - 队列化 Research 爬虫 worker 会基于 Redis/BullMQ 管理 run 入队、后台执行和重试。
# 怎么获得：
# - 推荐使用本项目自带 Docker Compose：
#   `docker compose up -d redis`
# - Compose 会把 Redis 暴露到本机 `16379`，避免和其它项目的 `6379` 冲突。
# - 或者填你已有的 Redis 地址。
# 是否必填：
# - 只看 RSS/新闻时不必填。
# - 创建和运行 Research run 时必须填写；缺失时 Research API 会返回队列配置错误，但 RSS 新闻不受影响。
REDIS_URL="redis://localhost:16379"

# RESEARCH_WORKER_CONCURRENCY
# 是什么：
# - Research worker 同时处理多少个 run。
# - 每个 run 内部还会按 frontier 优先级逐步抓取 URL。
# 怎么获得/怎么填：
# - 本地开发建议 `1` 或 `2`。
# - 机器和搜索/抓取 API 限额更高时可以逐步增大。
# 是否必填：
# - 可选。缺省为 `2`。
RESEARCH_WORKER_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Analytics 数据处理、统计分析与可视化 worker
# -----------------------------------------------------------------------------

# ANALYTICS_PYTHON_BIN
# 是什么：
# - Node/Express 调用 Python Analytics Worker 时使用的 Python 可执行文件。
# - 用于 Data Lab 的 Python profile/stats、后续 SciPy/statsmodels/scikit-learn/PyTorch 分析。
# 怎么获得/怎么填：
# - 推荐用 uv：
#   最小环境：`cd workers-analytics && uv sync --python 3.12`
#   完整 Data Lab：`cd workers-analytics && uv sync --extra ml --extra reports --python 3.12`
# - 完整环境会安装 PyTorch、Transformers、sentence-transformers、SHAP 和 python-pptx。
# - 然后填 `.venv/bin/python`。注意：这个路径是相对 `ANALYTICS_WORKER_DIR` 的，不是相对项目根目录。
# - 如果用 conda，填对应环境里的 python，例如 `/Users/you/miniconda3/envs/politistream-analytics/bin/python`。
# - 也可以填绝对路径；本地未建专用环境时可临时填 `python3`，但建议后续独立环境管理。
# 是否必填：
# - 可选。缺省为 `python3`。
ANALYTICS_PYTHON_BIN=".venv/bin/python"

# ANALYTICS_WORKER_DIR
# 是什么：
# - Python Analytics Worker 的工作目录。
# - Node 会在这个目录下执行 `python -m politistream_analytics.worker ...`。
# 怎么获得/怎么填：
# - 本项目默认就是 `workers-analytics`。
# - 部署时填该目录的绝对路径更稳。
# 是否必填：
# - 可选。缺省为项目根目录下的 `workers-analytics`。
ANALYTICS_WORKER_DIR="workers-analytics"

# ANALYTICS_WORKER_TIMEOUT_MS
# 是什么：
# - 单次 Python analytics worker 任务的超时时间，单位毫秒。
# - 适用于 Data Lab 的 profile、描述统计、后续统计检验/模型/图表渲染任务。
# 怎么获得/怎么填：
# - 本地轻量统计建议 `120000`。
# - 大数据或模型任务应通过队列和更长 timeout 管理，不建议无限增大。
# 是否必填：
# - 可选。缺省为 `120000`。
ANALYTICS_WORKER_TIMEOUT_MS=120000

# ANALYTICS_IMPORT_MAX_ROWS
# 是什么：
# - Data Lab 多格式导入时最多解析多少行结构化数据。
# - 这不是前端展示行数；前端只显示 `sampleRows` 预览，完整 rows 会保存到 Postgres 并交给 worker 分析。
# 怎么获得/怎么填：
# - 普通研究数据建议 `50000`。
# - 比赛数据、平台数据、政府开放表格较大时可提高，但要同步评估 Postgres JSONB 存储体积和 worker timeout。
# - 如果只做 smoke test 或小样例，可临时设为 `1000`。
# 是否必填：
# - 可选。缺省为 `50000`。
ANALYTICS_IMPORT_MAX_ROWS=50000

# ANALYTICS_MATERIALIZE_MAX_ROWS
# 是什么：
# - 从 Research 数据源资产清单一键抓取 CSV/JSON/API 快照后，最多落库多少行。
# - 对应接口：`POST /api/analytics/datasets/:id/materialize-source`。
# 怎么获得/怎么填：
# - 普通开放数据源建议 `50000`。
# - 如果只是快速验证数据源是否可读，可以设为 `1000`。
# - 大型比赛/平台数据建议后续改成分块下载和对象存储，不建议无限提高。
# 是否必填：
# - 可选。缺省跟随 `ANALYTICS_IMPORT_MAX_ROWS`，再缺省为 `50000`。
ANALYTICS_MATERIALIZE_MAX_ROWS=50000

# ANALYTICS_MATERIALIZE_BATCH_LIMIT
# 是什么：
# - Data Lab 从“数据源资产清单”批量导入数据快照时，单次最多处理多少个候选 URL。
# - 对应接口：`POST /api/analytics/datasets/:id/materialize-sources`。
# - 每个 URL 独立成功/失败；失败原因会返回给前端，不会阻断其他 URL。
# 怎么获得/怎么填：
# - 普通本地调研建议 `8`，避免一次性请求太多开放数据源。
# - 如果你已经把抓取任务 worker 化、加了队列和速率限制，可逐步提高。
# 是否必填：
# - 可选。缺省为 `8`。
ANALYTICS_MATERIALIZE_BATCH_LIMIT=8

# ANALYTICS_SOURCE_FETCH_TIMEOUT_MS
# 是什么：
# - Data Lab 从远程数据源 URL 抓取 CSV/JSON/API 快照的 HTTP 超时时间，单位毫秒。
# 怎么获得/怎么填：
# - 本地和普通公网数据源建议 `30000`。
# - 慢速政府/比赛平台可提高到 `60000`，但应配合 worker 队列和重试策略。
# 是否必填：
# - 可选。缺省为 `30000`。
ANALYTICS_SOURCE_FETCH_TIMEOUT_MS=30000

# ANALYTICS_SOURCE_MAX_BYTES
# 是什么：
# - 单次 materialize 允许抓取的最大响应体大小，单位字节。
# - 防止误把超大数据包直接塞进 Postgres JSONB。
# 怎么获得/怎么填：
# - 默认 `26214400` 是 25 MiB。
# - 如果需要更大数据，建议先接对象存储/分块解析，再提高这个值。
# 是否必填：
# - 可选。缺省为 25 MiB。
ANALYTICS_SOURCE_MAX_BYTES=26214400

# ANALYTICS_SOURCE_ALLOW_PRIVATE_NETWORKS
# 是什么：
# - Data Lab materialize 远程数据源时，是否允许请求 localhost、127.0.0.1、10.x、172.16-31.x、192.168.x、100.64.x 等本机/私网地址。
# - 默认 false 是安全设置，防止 Research 候选 URL 被滥用为 SSRF/内网探测入口。
# 怎么获得/怎么填：
# - 正式运行、团队环境和公网部署必须保持 `false`。
# - 只有你明确要测试本机 mock 数据服务时，才临时改成 `true`，测试后恢复。
# 是否必填：
# - 可选。缺省为 `false`。
ANALYTICS_SOURCE_ALLOW_PRIVATE_NETWORKS=false

# ANALYTICS_ALLOW_LOCAL_FALLBACK
# 是什么：
# - 是否允许 Data Lab 在 Postgres 不可用时降级写入本地 JSON。
# - 本项目正式目标是 Postgres，因此默认必须为 `false`。
# - 只有临时离线开发、CI smoke 或故障演示时才改为 `true`。
# 怎么获得/怎么填：
# - 不需要获取；按场景填 `true` 或 `false`。
# - 如果你看到 `analytics_postgres_unavailable`，优先修 `DATABASE_URL` / `docker compose up -d postgres`，不要直接打开 fallback。
# 是否必填：
# - 可选。缺省为 `false`。
ANALYTICS_ALLOW_LOCAL_FALLBACK=false

# ANALYTICS_STORE_FILE
# 是什么：
# - Data Lab 的本地 JSON metadata fallback 文件路径。
# - 只有 `ANALYTICS_ALLOW_LOCAL_FALLBACK=true` 且 Postgres 不可用时才会使用。
# - Research 深度爬虫始终使用 `DATABASE_URL`，不会写入这个 JSON 文件。
# 怎么获得/怎么填：
# - 临时本地 fallback 可填 `.data/analytics-store.json`。
# - 正式研究、长期数据资产和团队环境不要依赖它。
# 是否必填：
# - 可选。只在显式开启 fallback 时有意义。
ANALYTICS_STORE_FILE=".data/analytics-store.json"

# ANALYTICS_ARTIFACT_DIR
# 是什么：
# - Analytics 分析资产、导出图表、报告草稿和正式报告的保存目录。
# - Python worker 的 `chart` 会在这里写入 PNG/SVG/PDF；`export` 会写入 MD/HTML/DOCX/PDF/PPTX/JSON。
# - 前端 Data Lab 会通过 `/api/analytics/artifact-files?path=...` 下载该目录内文件。
# 怎么获得/怎么填：
# - 本地建议 `.data/analytics-artifacts`。
# - 线上可换成挂载磁盘目录或对象存储映射目录。
# 是否必填：
# - 可选。启用图表/报告导出时建议填写。
ANALYTICS_ARTIFACT_DIR=".data/analytics-artifacts"

# ANALYTICS_USE_DOC_TOOLS
# 是什么：
# - 是否让 Python analytics worker 在 `export` 报告时优先调用本机 Codex 文档工具链。
# - true：优先 `codex-md-to-docx` / `codex-md-to-pdf`，适合正式中文 DOCX/PDF 交付。
# - false：跳过外部转换，使用 worker 内置快速 fallback，适合 CI、smoke test 或没有 LibreOffice/Pandoc 的环境。
# 怎么获得/怎么填：
# - 本机已安装 Codex 文档工具链，正式使用建议 `true`。
# - 如果导出阶段过慢或服务器缺文档工具，可临时改成 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
ANALYTICS_USE_DOC_TOOLS=true

# ANALYTICS_CHART_EXPORT_FORMATS
# 是什么：
# - 默认允许导出的图表格式。
# - 用于论文图、交互图、工程图的导出按钮和后端 renderer 校验。
# 怎么获得/怎么填：
# - 常用值：`png,svg,pdf,html,json`。
# - 如果服务器缺少某些渲染依赖，可先删掉对应格式。
# 是否必填：
# - 可选。
ANALYTICS_CHART_EXPORT_FORMATS="png,svg,pdf,html,json"

# -----------------------------------------------------------------------------
# 搜索发现服务
# -----------------------------------------------------------------------------

# BRAVE_API_KEY
# 是什么：
# - Brave Search API key。
# - 用作深度研究的网页搜索 discovery provider。
# 怎么获得：
# - 打开 https://api.search.brave.com/
# - 创建 API subscription/key。
# - 把 key 粘贴到这里。
# 是否必填：
# - 如果使用 SerpApi 或 Tavily，可以不填。
# - 要做真实网页搜索，至少需要填写一个搜索 provider key。
BRAVE_API_KEY=""

# SERPAPI_API_KEY
# 是什么：
# - SerpApi API key。
# - 通过 SerpApi 获取 Google 风格搜索结果。
# 怎么获得：
# - 打开 https://serpapi.com/
# - 注册后进入 dashboard，复制 private API key。
# 是否必填：
# - 如果使用 Brave 或 Tavily，可以不填。
# - 要做真实网页搜索，至少需要填写一个搜索 provider key。
SERPAPI_API_KEY=""

# TAVILY_API_KEY
# 是什么：
# - Tavily Search API key。
# - 用作偏研究场景的搜索 provider。
# 怎么获得：
# - 打开 https://tavily.com/
# - 注册后进入 dashboard/API keys 页面，复制 API key。
# 是否必填：
# - 如果使用 Brave 或 SerpApi，可以不填。
# - 要做真实网页搜索，至少需要填写一个搜索 provider key。
TAVILY_API_KEY=""

# NEWSAPI_KEY
# 是什么：
# - NewsAPI API key。
# - 用于新闻补盲搜索，适合补充主流媒体和时效性新闻来源。
# 怎么获得：
# - 打开 https://newsapi.org/
# - 注册账号并在 dashboard 里复制 API key。
# 是否必填：
# - 可选。不填时 NewsAPI provider 会保持未启用。
NEWSAPI_KEY=""

# NEWS_API_KEY
# 是什么：
# - NewsAPI 的兼容变量名。
# - 代码会按 `NEWSAPI_KEY || NEWS_API_KEY` 读取，两者填一个即可。
# 怎么获得：
# - 同 `NEWSAPI_KEY`，来自 https://newsapi.org/ 的 API key。
# 是否必填：
# - 可选。推荐优先填写 `NEWSAPI_KEY`，这个变量主要用于兼容其它文档或旧配置。
NEWS_API_KEY=""

# GITHUB_TOKEN
# 是什么：
# - GitHub Personal Access Token。
# - GitHub discovery/extractor 可无 token 运行，但 GitHub API 未认证请求限额很低。
# - 填写后可提高 repo 搜索、README、stars、license、release 等元数据抓取稳定性。
# 怎么获得：
# - 打开 https://github.com/settings/tokens
# - 创建 fine-grained token 或 classic token。
# - 公开仓库调研通常不需要额外权限，保持只读即可。
# 是否必填：
# - 可选。需要大量调研 GitHub 项目时建议填写。
GITHUB_TOKEN=""

# FRED_API_KEY
# 是什么：
# - Federal Reserve Economic Data API key。
# - 用于 FRED 经济/金融时间序列 provider。
# 怎么获得：
# - 打开 https://fred.stlouisfed.org/docs/api/api_key.html
# - 注册并申请 API key。
# 是否必填：
# - 可选。不填时 FRED provider 会显示未启用，其他数据源不受影响。
FRED_API_KEY=""

# KAGGLE_USERNAME
# 是什么：
# - Kaggle API 用户名。
# - 用于后续 Kaggle competition/dataset provider 下载用户有权限的数据。
# 怎么获得：
# - 打开 Kaggle Account 页面，创建 API token。
# - `kaggle.json` 里的 `username` 填到这里。
# 是否必填：
# - 可选。只搜索公开 Kaggle 页面可不填；下载授权数据时需要。
KAGGLE_USERNAME=""

# KAGGLE_KEY
# 是什么：
# - Kaggle API key。
# 怎么获得：
# - 打开 Kaggle Account 页面，点击 Create New Token。
# - `kaggle.json` 里的 `key` 填到这里。
# 是否必填：
# - 可选。下载 Kaggle 授权数据时需要。
KAGGLE_KEY=""

# FIRECRAWL_API_KEY
# 是什么：
# - Firecrawl API key，用于可选 hosted scrape/crawl/map/batch provider。
# 怎么获得：
# - 打开 https://www.firecrawl.dev/ 或 Firecrawl 控制台创建 key。
# 是否必填：
# - 可选。不填时本地 HTTP/browser/Crawl4AI 等路径仍可用。
FIRECRAWL_API_KEY=""

# CRAWL4AI_URL
# 是什么：
# - 自托管 Crawl4AI API 服务地址。
# - 用作 LLM-ready Markdown、深度抓取和结构化抽取 fallback。
# 怎么获得/怎么填：
# - 本地或服务器启动 Crawl4AI 后填入，例如 `http://localhost:11235`。
# 是否必填：
# - 可选。不填时跳过 Crawl4AI provider。
CRAWL4AI_URL=""

# RESEARCH_BROWSER_PROVIDER
# 是什么：
# - 浏览器抓取 provider。
# - `local` 使用本机 Puppeteer/Playwright 类浏览器；`browserless` 使用远程 Browserless。
# 怎么获得/怎么填：
# - 本地开发保持 `local`。
# - 如果使用 Browserless，填 `browserless` 并配置 `BROWSERLESS_URL`。
# 是否必填：
# - 可选。缺省为 `local`。
RESEARCH_BROWSER_PROVIDER="local"

# BROWSERLESS_URL
# 是什么：
# - Browserless WebSocket/HTTP 连接地址，用于远程浏览器池。
# 怎么获得：
# - 使用 Browserless Cloud 或自托管 Browserless Docker 后，从控制台/服务日志获取 endpoint。
# 是否必填：
# - 仅当 `RESEARCH_BROWSER_PROVIDER=browserless` 时需要。
BROWSERLESS_URL=""

# -----------------------------------------------------------------------------
# Research 抓取策略
# -----------------------------------------------------------------------------

# RESEARCH_FETCH_MAX_ATTEMPTS
# 是什么：
# - 单个 URL 抓取失败后的最大尝试次数。
# - 对 429、5xx、超时等临时错误会重试；404 这类确定失败不会无意义重试。
# 怎么获得/怎么填：
# - 本地开发建议 `3`。
# - 如果搜索 provider 或目标站点经常限流，可以降低并发而不是盲目增大这个值。
# 是否必填：
# - 可选。缺省为 `3`。
RESEARCH_FETCH_MAX_ATTEMPTS=3

# RESEARCH_DOMAIN_MIN_DELAY_MS
# 是什么：
# - 同一个域名两次抓取之间的最小间隔，单位毫秒。
# - 用来做礼貌抓取，降低被目标站点限流或封禁的概率。
# 怎么获得/怎么填：
# - 本地开发建议 `1500`。
# - 更深度抓取时建议保持或增大，不建议设置为 0。
# 是否必填：
# - 可选。缺省为 `1500`。
RESEARCH_DOMAIN_MIN_DELAY_MS=1500

# RESEARCH_RESPECT_ROBOTS_TXT
# 是什么：
# - 是否读取并尊重目标站点的 robots.txt。
# 怎么获得/怎么填：
# - 生产与真实调研建议保持 `true`。
# - 只有本地 mock/test 场景才考虑设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_RESPECT_ROBOTS_TXT=true

# RESEARCH_BROWSER_FETCH_ENABLED
# 是什么：
# - 是否允许对动态网页启用 Puppeteer 浏览器抓取 fallback。
# - 当静态 HTML 抓不到正文、或 URL 明显是 SPA 时会用到。
# 怎么获得/怎么填：
# - 本地机器安装依赖后可保持 `true`。
# - 如果机器资源紧张、CI 不希望启动浏览器，可设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_BROWSER_FETCH_ENABLED=true

# RESEARCH_BROWSER_MAX_PAGES
# 是什么：
# - Puppeteer 同时打开的最大页面数。
# 怎么获得/怎么填：
# - 本地开发建议 `2`。
# - 机器性能更强时可逐步增大，但要配合域名限速和总 URL 预算。
# 是否必填：
# - 可选。缺省为 `2`。
RESEARCH_BROWSER_MAX_PAGES=2

# RESEARCH_FETCH_TIMEOUT_MS
# 是什么：
# - 单次 HTTP 或浏览器抓取的超时时间，单位毫秒。
# 怎么获得/怎么填：
# - 本地开发建议 `15000`。
# - 网络较慢或 PDF 较多时可增大到 `30000`。
# 是否必填：
# - 可选。缺省为 `15000`。
RESEARCH_FETCH_TIMEOUT_MS=15000

# RESEARCH_MAX_CONTENT_BYTES
# 是什么：
# - 单个响应允许读取的最大字节数。
# - 防止超大 HTML/PDF 把内存或数据库拖垮。
# 怎么获得/怎么填：
# - 默认 `5242880`，约 5MB。
# - 如需抓较大 PDF，可适当增大。
# 是否必填：
# - 可选。缺省为 5MB。
RESEARCH_MAX_CONTENT_BYTES=5242880

# -----------------------------------------------------------------------------
# Research 原始内容资产
# -----------------------------------------------------------------------------

# RESEARCH_ASSET_DIR
# 是什么：
# - Research 原始 HTML、PDF、抽取文本的本地保存目录。
# - Postgres 保存 metadata 和索引，原始大文件保存在这个目录，避免数据库无限膨胀。
# 怎么获得/怎么填：
# - 本地开发建议保持 `.data/research-assets`。
# - 线上可换成挂载磁盘目录；后续也可以替换为对象存储。
# 是否必填：
# - 可选。缺省为 `.data/research-assets`。
RESEARCH_ASSET_DIR=".data/research-assets"

# RESEARCH_STORE_RAW_HTML
# 是什么：
# - 是否保存抓取到的原始 HTML/XML/text 响应。
# 怎么获得/怎么填：
# - 调试抓取质量和复查来源时建议 `true`。
# - 存储空间紧张时可设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_STORE_RAW_HTML=true

# RESEARCH_STORE_RAW_PDF
# 是什么：
# - 是否保存抓取到的原始 PDF 文件。
# 怎么获得/怎么填：
# - 需要复核 PDF 原文时建议 `true`。
# - 如果只保留抽取文本，可设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_STORE_RAW_PDF=true

# RESEARCH_STORE_RAW_TEXT
# 是什么：
# - 是否把抽取后的正文文本另存为 `.txt` 资产。
# 怎么获得/怎么填：
# - 建议保持 `true`，便于后续离线检索、调试和报告复核。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_STORE_RAW_TEXT=true

# -----------------------------------------------------------------------------
# Research 记忆复用
# -----------------------------------------------------------------------------

# RESEARCH_MEMORY_ENABLED
# 是什么：
# - 是否允许后续 Research run 复用历史已抓取文档和来源记忆。
# 怎么获得/怎么填：
# - 本地和生产建议保持 `true`，可以减少重复抓取并加快同主题调研。
# - 如果需要强制每次重新抓取，设为 `false`。
# 是否必填：
# - 可选。缺省为 `true`。
RESEARCH_MEMORY_ENABLED=true

# RESEARCH_MEMORY_MAX_AGE_HOURS
# 是什么：
# - 历史文档可被复用的最大年龄，单位小时。
# 怎么获得/怎么填：
# - 新闻溯源建议较短，例如 `24`。
# - 工具/技术文档调研可设为 `72` 或更高。
# 是否必填：
# - 可选。缺省为 `24`。
RESEARCH_MEMORY_MAX_AGE_HOURS=24

# -----------------------------------------------------------------------------
# 本地验收、UI smoke 与 E2E
# -----------------------------------------------------------------------------

# UI_SMOKE_FRONTEND_PORT
# 是什么：
# - `npm run test:ui` 启动前端 smoke 测试时使用的临时前端端口。
# - 这个端口和正常 `FRONTEND_PORT=3000` 分开，避免测试抢占你的开发页面。
# 怎么获得/怎么填：
# - 本地默认 `3300`。
# - 如果端口被占用，换成一个空闲端口即可。
# 是否必填：
# - 可选。只影响 `npm run test:ui`。
UI_SMOKE_FRONTEND_PORT=3300

# UI_SMOKE_BACKEND_PORT
# 是什么：
# - `npm run test:ui` 启动后端 mock/smoke API 时使用的临时端口。
# 怎么获得/怎么填：
# - 本地默认 `3301`。
# - 如果端口被占用，换成一个空闲端口即可。
# 是否必填：
# - 可选。只影响 `npm run test:ui`。
UI_SMOKE_BACKEND_PORT=3301

# UI_SMOKE_URL
# 是什么：
# - UI smoke 直接访问的前端地址。
# - 留空时脚本会自动用 `http://localhost:${UI_SMOKE_FRONTEND_PORT}`。
# 怎么获得/怎么填：
# - 本地通常留空。
# - 如果你已经手动启动了前端并想让 smoke 复用该地址，可填实际 URL。
# 是否必填：
# - 可选。
UI_SMOKE_URL=""

# UI_SMOKE_API_URL
# 是什么：
# - UI smoke 使用的后端 API 地址。
# - 留空时脚本会自动用 `http://localhost:${UI_SMOKE_BACKEND_PORT}`。
# 怎么获得/怎么填：
# - 本地通常留空。
# - 如果你想让 smoke 指向已有后端，可填实际后端 URL。
# 是否必填：
# - 可选。
UI_SMOKE_API_URL=""

# PLAYWRIGHT_CHROME_PATH
# 是什么：
# - Playwright smoke 测试使用的 Chrome 可执行文件路径。
# - 本机优先使用真实 Chrome，能更接近用户浏览器效果。
# 怎么获得/怎么填：
# - macOS 默认通常是 `/Applications/Google Chrome.app/Contents/MacOS/Google Chrome`。
# - 如果 Chrome 安装在其它位置，填实际可执行文件路径。
# - 也可在终端运行：
#   `/usr/bin/mdfind "kMDItemCFBundleIdentifier == 'com.google.Chrome'"`
# 是否必填：
# - 可选。只影响 UI smoke；缺省值同下面默认路径。
PLAYWRIGHT_CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# E2E_FRONTEND_PORT
# 是什么：
# - `npm run test:research-e2e` 使用的临时前端端口。
# 怎么获得/怎么填：
# - 默认 `3310`；冲突时换空闲端口。
# 是否必填：
# - 可选。只影响 Research E2E smoke。
E2E_FRONTEND_PORT=3310

# E2E_BACKEND_PORT
# 是什么：
# - `npm run test:research-e2e` 使用的临时后端端口。
# 怎么获得/怎么填：
# - 默认 `3311`；冲突时换空闲端口。
# 是否必填：
# - 可选。只影响 Research E2E smoke。
E2E_BACKEND_PORT=3311

# E2E_FIXTURE_PORT
# 是什么：
# - Research E2E smoke 内置测试 fixture 网站使用的端口。
# - 测试会用它模拟可抓取网页，不依赖真实外网。
# 怎么获得/怎么填：
# - 默认 `3322`；冲突时换空闲端口。
# 是否必填：
# - 可选。只影响 Research E2E smoke。
E2E_FIXTURE_PORT=3322

# E2E_REDIS_URL
# 是什么：
# - Research E2E smoke 专用 Redis URL。
# - 留空时脚本会基于 `REDIS_URL` 自动隔离到测试 DB。
# 怎么获得/怎么填：
# - 本地通常留空。
# - 如果你想让 E2E 使用单独 Redis，可填例如 `redis://localhost:16379/9`。
# 是否必填：
# - 可选。只影响 Research E2E smoke。
E2E_REDIS_URL=""

# E2E_REDIS_DB
# 是什么：
# - 当 `E2E_REDIS_URL` 留空时，脚本会把 `REDIS_URL` 改写到这个 Redis DB。
# - 用于避免 E2E 清理影响正常开发队列。
# 怎么获得/怎么填：
# - 默认 `9`。
# - 如果你的 Redis DB 9 已被其它项目使用，换成空闲 DB 编号。
# 是否必填：
# - 可选。只影响 Research E2E smoke。
E2E_REDIS_DB=9

# RESEARCH_DISCOVERY_OFFLINE_ONLY
# 是什么：
# - 是否让 Research discovery provider 使用确定性的离线候选结果。
# - 主要用于单元测试、UI smoke、E2E smoke 和无外网/无 provider key 的验收。
# 怎么获得/怎么填：
# - 正常运行必须保持 `false`，否则不会真实搜索公网。
# - 跑离线测试或排查 UI 时可临时设为 `true`。
# 是否必填：
# - 可选。缺省为 `false`。
RESEARCH_DISCOVERY_OFFLINE_ONLY=false

# RESEARCH_SMOKE_DIR
# 是什么：
# - `npm run smoke:research-capabilities` 保存能力验收临时产物的目录。
# 怎么获得/怎么填：
# - 本地默认 `.data/research-smoke`。
# - 该目录属于运行产物，不应提交。
# 是否必填：
# - 可选。只影响 Research capability smoke。
RESEARCH_SMOKE_DIR=".data/research-smoke"
